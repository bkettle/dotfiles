[alias]
  lol = log --graph --oneline --color --branches
  lolall = log --graph --oneline --color --all
  gr = log --graph --format=line 
	gra = log --graph --format=line --all
	pullrb = pull --rebase
	update-submodules = submodule update --init --recursive
	upgrade-submodules = submodule update --init --remote
  pulp = pull -j16 # pull and fetch submodules in parallel
  pl = pull
  ps = push
  co = checkout
  cob = checkout -b
  s = status
  sta = status
	st = status -sb
  sh = stash
  c = commit

[submodule]
  recurse = true
  fetchJobs = 20

[credential]
	helper = store

[init]
	defaultBranch = main

[user]
	useConfigOnly = true

[pretty]
  line = "%C(auto)%h %<|(60,trunc)%s  %C(green)%ad %C(magenta)<%ae>%C(auto)%d"
  detail = "%C(auto)%h %s%n  %C(yellow)by %C(blue)%an %C(magenta)<%ae> [%G?] %C(green)%ad%n %C(auto)%d%n"


[push]
	default = upstream
  autoSetupRemote = true

[merge]
  conflictStyle = zdiff3

[core]
  pager = delta

[delta]
  minus-style = red ul darkred
  plus-style = green bold darkgreen

# non-version-controlled settings
[include]
	path = ~/.gitconfig_local
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f

[rerere]
	enabled = true
